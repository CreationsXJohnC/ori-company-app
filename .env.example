# ─────────────────────────────────────────────────────────────
# ORI APP — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Stripe ────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API Keys
# Use TEST keys for dev, LIVE keys for production
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── OpenAI ────────────────────────────────────────────────────
# Get from: platform.openai.com → API Keys
# Used in Supabase Edge Functions (server-side only)
OPENAI_API_KEY=sk-your_openai_api_key

# ── App Config ────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development
# Options: development | staging | production

# ── Social Links ──────────────────────────────────────────────
# Update these with actual URLs
EXPO_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@OriCompanyDC
EXPO_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/oricompanydc
EXPO_PUBLIC_WEBSITE_URL=https://www.oricompanydc.com

# ── Notifications ─────────────────────────────────────────────
# Get from: Expo Dashboard (after EAS build)
EXPO_PUBLIC_PROJECT_ID=your_eas_project_id
